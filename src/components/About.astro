---
import data from '../content/about.json';
---
<section id="o-nas" class="py-24 bg-zinc-900">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Image side -->
      <div class="relative order-2 lg:order-1">
        <img
          src="https://images.pexels.com/photos/69483/pexels-photo-69483.jpeg?auto=compress&cs=tinysrgb&w=900"
          alt="Výkopy a zemní práce v Libereckém kraji"
          class="rounded-xl w-full object-cover aspect-[4/3]"
          loading="lazy"
          width="900"
          height="675"
        />
        <div class="absolute -bottom-4 -right-4 bg-accent rounded-xl p-5 shadow-xl">
          <div class="text-dark font-black text-3xl leading-none">10+</div>
          <div class="text-dark/70 text-xs font-bold uppercase tracking-wide mt-1">let zkušeností</div>
        </div>
      </div>

      <!-- Text side -->
      <div class="order-1 lg:order-2">
        <h2 class="text-3xl md:text-5xl font-black uppercase leading-tight mb-6">
          {data.heading}<br/><span class="text-accent"> {data.heading_accent}</span>
        </h2>
        <p class="text-white/65 leading-relaxed mb-8 text-lg">{data.desc}</p>

        <ul class="space-y-4">
          {data.points.map((point) => (
            <li class="flex items-start gap-4">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-accent/15 border border-accent/40 flex items-center justify-center mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <span class="text-white/80 leading-relaxed">{point}</span>
            </li>
          ))}
        </ul>

        <div class="mt-10">
          <a href="#kontakt" class="inline-block bg-accent text-dark font-black px-8 py-3 rounded hover:bg-yellow-300 transition-colors uppercase tracking-wide text-sm">
            Kontaktovat nás
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
