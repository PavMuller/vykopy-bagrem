---
import data from '../content/about.json';
---
<section id="o-nas" class="py-28 bg-surface">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">

      <!-- Image -->
      <div class="relative">
        <img
          src="https://images.pexels.com/photos/69483/pexels-photo-69483.jpeg?auto=compress&cs=tinysrgb&w=900"
          alt="Zemní práce Liberecko"
          class="w-full object-cover aspect-[4/3]"
          loading="lazy"
          width="900"
          height="675"
        />
        <!-- Yellow stat box -->
        <div class="absolute -bottom-6 -right-6 bg-accent p-8 shadow-2xl">
          <div class="font-display text-5xl text-dark leading-none">10+</div>
          <div class="text-dark/70 text-xs font-black uppercase tracking-widest mt-1">Let v oboru</div>
        </div>
      </div>

      <!-- Text -->
      <div>
        <span class="section-label">O nás</span>
        <h2 class="font-display text-5xl md:text-7xl text-white mt-3 leading-none">
          {data.heading}<span class="text-accent"> {data.heading_accent}</span>
        </h2>
        <span class="divider-accent"></span>

        <p class="text-white/60 leading-relaxed mt-8 mb-10 text-lg">{data.desc}</p>

        <ul class="space-y-4 mb-10">
          {data.points.map((point) => (
            <li class="flex items-start gap-4">
              <div class="flex-shrink-0 w-5 h-5 bg-accent flex items-center justify-center mt-0.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-white/75 leading-relaxed">{point}</span>
            </li>
          ))}
        </ul>

        <a href="#kontakt"
           class="inline-flex items-center gap-3 bg-accent text-dark font-black text-sm px-8 py-4 uppercase tracking-widest hover:bg-yellow-300 transition-all group">
          Kontaktovat nás
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
