---
import data from '../content/contact.json';
---
<section id="kontakt" class="py-28 bg-dark">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-16">
      <span class="section-label">Kontakt</span>
      <h2 class="font-display text-5xl md:text-7xl text-white mt-3">
        {data.heading}<span class="text-accent"> {data.heading_accent}</span>
      </h2>
      <span class="divider-accent"></span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- Contact info (2 cols) -->
      <div class="lg:col-span-2 space-y-4">
        <a href={`tel:${data.phone.replace(/\s/g, '')}`}
           class="group flex items-center gap-5 p-6 border border-white/8 hover:border-accent/50 bg-surface transition-all">
          <div class="w-12 h-12 bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <div class="text-white/40 text-xs uppercase tracking-widest font-bold mb-1">Telefon</div>
            <div class="font-display text-2xl text-white group-hover:text-accent transition-colors">{data.phone}</div>
          </div>
        </a>

        <a href={`mailto:${data.email}`}
           class="group flex items-center gap-5 p-6 border border-white/8 hover:border-accent/50 bg-surface transition-all">
          <div class="w-12 h-12 bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <div class="text-white/40 text-xs uppercase tracking-widest font-bold mb-1">E-mail</div>
            <div class="font-display text-xl text-white group-hover:text-accent transition-colors">{data.email}</div>
          </div>
        </a>

        <div class="flex items-center gap-5 p-6 border border-white/8 bg-surface">
          <div class="w-12 h-12 bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <div class="text-white/40 text-xs uppercase tracking-widest font-bold mb-1">Lokalita</div>
            <div class="font-display text-xl text-white">{data.location}</div>
          </div>
        </div>

        <div class="p-6 border-l-4 border-accent bg-surface mt-2">
          <p class="text-white/50 text-sm leading-relaxed">{data.note}</p>
        </div>
      </div>

      <!-- Form (3 cols) -->
      <form
        class="lg:col-span-3 space-y-4"
        action="https://formspree.io/f/REPLACE_WITH_YOUR_ID"
        method="POST"
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="jmeno" class="block text-xs font-black uppercase tracking-widest text-white/40 mb-2">Jméno *</label>
            <input type="text" id="jmeno" name="jmeno" required
              class="w-full bg-surface border border-white/10 px-4 py-3.5 text-white placeholder-white/20 focus:outline-none focus:border-accent transition-colors"
              placeholder="Jan Novák" />
          </div>
          <div>
            <label for="telefon" class="block text-xs font-black uppercase tracking-widest text-white/40 mb-2">Telefon *</label>
            <input type="tel" id="telefon" name="telefon" required
              class="w-full bg-surface border border-white/10 px-4 py-3.5 text-white placeholder-white/20 focus:outline-none focus:border-accent transition-colors"
              placeholder="+420 777 123 456" />
          </div>
        </div>
        <div>
          <label for="email" class="block text-xs font-black uppercase tracking-widest text-white/40 mb-2">E-mail</label>
          <input type="email" id="email" name="email"
            class="w-full bg-surface border border-white/10 px-4 py-3.5 text-white placeholder-white/20 focus:outline-none focus:border-accent transition-colors"
            placeholder="jan@email.cz" />
        </div>
        <div>
          <label for="lokalita" class="block text-xs font-black uppercase tracking-widest text-white/40 mb-2">Lokalita / obec</label>
          <input type="text" id="lokalita" name="lokalita"
            class="w-full bg-surface border border-white/10 px-4 py-3.5 text-white placeholder-white/20 focus:outline-none focus:border-accent transition-colors"
            placeholder="Český Dub, Liberec..." />
        </div>
        <div>
          <label for="zprava" class="block text-xs font-black uppercase tracking-widest text-white/40 mb-2">Popis prací *</label>
          <textarea id="zprava" name="zprava" required rows="5"
            class="w-full bg-surface border border-white/10 px-4 py-3.5 text-white placeholder-white/20 focus:outline-none focus:border-accent transition-colors resize-none"
            placeholder="Popište rozsah prací, hloubku, termín..."></textarea>
        </div>
        <button type="submit"
          class="w-full bg-accent text-dark font-black py-4 uppercase tracking-widest text-sm hover:bg-yellow-300 transition-colors flex items-center justify-center gap-3 group">
          Odeslat poptávku
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </button>
      </form>

    </div>
  </div>
</section>
