---
import data from '../content/machine.json';
---
<section id="technika" class="py-24 bg-dark">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text side -->
      <div>
        <h2 class="text-3xl md:text-5xl font-black uppercase leading-tight mb-6">
          {data.heading}<br/><span class="text-accent"> {data.heading_accent}</span>
        </h2>
        <p class="text-white/65 leading-relaxed mb-10 text-lg">{data.desc}</p>

        <!-- Specs grid -->
        <div class="grid grid-cols-2 gap-4">
          {data.specs.map((spec) => (
            <div class="border border-white/10 rounded-lg p-5 hover:border-accent/40 transition-colors">
              <div class="text-accent text-xs font-black uppercase tracking-widest mb-2">{spec.label}</div>
              <div class="text-2xl font-black text-white">{spec.value}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Image side -->
      <div class="relative">
        <div class="absolute -inset-2 border border-accent/20 rounded-xl pointer-events-none"></div>
        <img
          src="https://images.pexels.com/photos/6245621/pexels-photo-6245621.jpeg?auto=compress&cs=tinysrgb&w=900"
          alt="Minirypadlo CAT 302.5 při práci"
          class="rounded-xl w-full object-cover aspect-[4/3]"
          loading="lazy"
          width="900"
          height="675"
        />
        <!-- Yellow badge overlay -->
        <div class="absolute bottom-4 left-4 bg-dark/90 border border-accent/50 rounded-lg px-4 py-2">
          <span class="text-accent font-black text-sm tracking-wider">CAT 302.5</span>
          <span class="text-white/60 text-xs block">Minirypadlo</span>
        </div>
      </div>
    </div>
  </div>
</section>
