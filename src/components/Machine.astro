---
import data from '../content/machine.json';
---
<section id="technika" class="py-28 bg-surface">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Image -->
      <div class="relative order-2 lg:order-1">
        <!-- Decorative frame -->
        <div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-accent"></div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border-b-2 border-r-2 border-accent"></div>

        <img
          src="https://images.pexels.com/photos/6245621/pexels-photo-6245621.jpeg?auto=compress&cs=tinysrgb&w=900"
          alt="Minirypadlo CAT 302.5"
          class="w-full object-cover aspect-[4/3] relative z-10"
          loading="lazy"
          width="900"
          height="675"
        />

        <!-- Badge -->
        <div class="absolute bottom-6 left-6 z-20 bg-dark border-l-4 border-accent px-5 py-3">
          <div class="font-display text-2xl text-accent">CAT 302.5</div>
          <div class="text-white/50 text-xs uppercase tracking-widest">Minirypadlo</div>
        </div>
      </div>

      <!-- Text -->
      <div class="order-1 lg:order-2">
        <span class="section-label">Naše technika</span>
        <h2 class="font-display text-5xl md:text-7xl text-white mt-3 leading-none">
          {data.heading}<span class="text-accent"> {data.heading_accent}</span>
        </h2>
        <span class="divider-accent"></span>

        <p class="text-white/55 leading-relaxed mt-8 mb-10">{data.desc}</p>

        <!-- Specs -->
        <div class="grid grid-cols-2 gap-3">
          {data.specs.map((spec) => (
            <div class="border border-white/8 p-5 bg-dark hover:border-accent/40 transition-colors group">
              <div class="text-accent text-xs font-black uppercase tracking-widest mb-2 group-hover:text-yellow-300 transition-colors">{spec.label}</div>
              <div class="font-display text-3xl text-white">{spec.value}</div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
