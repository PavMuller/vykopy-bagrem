---
import data from '../content/services.json';
---
<section id="sluzby" class="py-28 bg-surface">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Section header -->
    <div class="mb-16">
      <span class="section-label">Co nabízíme</span>
      <h2 class="font-display text-5xl md:text-7xl text-white mt-3">
        {data.heading}<span class="text-accent"> {data.heading_accent}</span>
      </h2>
      <span class="divider-accent"></span>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/5">
      {data.items.map((item, i) => (
        <div class="group relative bg-surface p-10 hover:bg-surface2 transition-all duration-300 overflow-hidden">
          <!-- Number watermark -->
          <div class="absolute top-4 right-6 font-display text-8xl text-white/3 leading-none select-none">
            {String(i + 1).padStart(2, '0')}
          </div>

          <!-- Yellow top border on hover -->
          <div class="absolute top-0 left-0 right-0 h-0.5 bg-accent scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>

          <div class="relative z-10">
            <!-- Icon -->
            <div class="w-14 h-14 border border-accent/30 bg-accent/5 flex items-center justify-center mb-6 group-hover:bg-accent/15 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>

            <h3 class="font-display text-2xl md:text-3xl text-white mb-4 group-hover:text-accent transition-colors">
              {item.title}
            </h3>
            <p class="text-white/50 leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
