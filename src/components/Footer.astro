---
import data from '../content/contact.json';
const year = new Date().getFullYear();
---
<footer class="bg-surface border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Logo & desc -->
      <div>
        <a href="/">
          <img src="/logo.png" alt="Výkopy bagrem" class="h-48 w-auto mb-4" />
        </a>
        <p class="text-white/35 text-sm leading-relaxed">
          Profesionální výkopy a zemní práce v Libereckém kraji. Operujeme s minirypadlem CAT 302.5.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <div class="text-white/25 text-xs uppercase tracking-widest font-bold mb-4">Navigace</div>
        <ul class="space-y-2">
          {[
            ['#sluzby', 'Služby'],
            ['#jak-pracujeme', 'Jak pracujeme'],
            ['#technika', 'Technika'],
            ['#o-nas', 'O nás'],
            ['#reference', 'Reference'],
            ['#kontakt', 'Kontakt'],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="text-white/40 hover:text-accent transition-colors text-sm">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <div class="text-white/25 text-xs uppercase tracking-widest font-bold mb-4">Kontakt</div>
        <ul class="space-y-3">
          <li>
            <a href={`tel:${data.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 text-white/40 hover:text-accent transition-colors text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {data.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${data.email}`} class="flex items-center gap-2 text-white/40 hover:text-accent transition-colors text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {data.email}
            </a>
          </li>
          <li class="flex items-center gap-2 text-white/40 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {data.location}
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/5 mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/20 text-xs">
        © {year} Výkopy bagrem · {data.location}
      </p>
      <p class="text-white/15 text-xs">
        Zemní práce · Inženýrské sítě · Terénní úpravy · Liberecký kraj
      </p>
    </div>
  </div>
</footer>
