---
import data from '../content/contact.json';
---
<section class="bg-accent py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <div class="font-display text-4xl md:text-6xl text-dark leading-none mb-2">
          Potřebujete výkop?
        </div>
        <p class="text-dark/60 font-medium">Zavolejte nebo napište — odpovíme do 24 hodin.</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 flex-shrink-0">
        <a href={`tel:${data.phone.replace(/\s/g, '')}`}
           class="inline-flex items-center justify-center gap-3 bg-dark text-white font-black text-sm px-8 py-4 uppercase tracking-widest hover:bg-zinc-800 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {data.phone}
        </a>
        <a href="#kontakt"
           class="inline-flex items-center justify-center gap-3 border-2 border-dark text-dark font-black text-sm px-8 py-4 uppercase tracking-widest hover:bg-dark hover:text-accent transition-all">
          Napsat poptávku
        </a>
      </div>
    </div>
  </div>
</section>
